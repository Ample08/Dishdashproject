# Server (Local XAMPP)
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (XAMPP MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dishdash_flavours
DB_USER=root
DB_PASSWORD=

# JWT (api-key header + access-token)
JWT_SECRET=dishdash_jwt_secret_key_2026_secure
JWT_EXPIRES_IN=7d

# OTP (mock mode: fixed code, no real SMS)
OTP_MOCK=true
OTP_FIXED_CODE=123456
OTP_EXPIRY_MINUTES=10

# Order live-status simulation (seconds per stage)
ORDER_STAGE_SECONDS=20
